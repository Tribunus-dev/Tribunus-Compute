<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>name</key>
    <string>Tribunus Local Inference</string>
    <key>description</key>
    <string>Local LLM inference on Apple Silicon via Tribunus Compute</string>
    <key>apiEndpoint</key>
    <string>http://localhost:11434/v1</string>
    <key>apiKey</key>
    <string></string>
    <key>model</key>
    <string>gemma4</string>
    <key>maxTokens</key>
    <integer>4096</integer>
    <key>temperature</key>
    <real>0.2</real>
    <key>streaming</key>
    <true/>
    <key>supports</key>
    <array>
        <string>code-completion</string>
        <string>code-generation</string>
        <string>documentation-generation</string>
    </array>
</dict>
</plist>
